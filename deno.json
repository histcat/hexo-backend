{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --watch main.ts",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "deploy": "deployctl deploy --project=hexo-backend main.ts"
  },
  "imports": {
    "jose": "npm:jose",
    "js-yaml": "npm:js-yaml"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
